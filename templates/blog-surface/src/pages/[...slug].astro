---
import { render } from "astro:content";
import { getPublishedPosts, postPath, postSlug, type BlogPost } from "../lib/posts";
import { siteConfig } from "../site.config";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import "@fontsource/fraunces/400.css";
import "@fontsource/fraunces/600.css";
import "@fontsource/fraunces/700.css";
import "@fontsource/fraunces/900.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/600.css";
import "../styles/global.css";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: postSlug(post) },
    props: { post },
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const { Content } = await render(post);
const canonicalUrl = post.data.canonicalUrl ?? new URL(postPath(post), siteConfig.url).toString();
const basePath = siteConfig.basePath === "/" ? "/" : `${siteConfig.basePath.replace(/\/$/, "")}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.title} | {siteConfig.name}</title>
    <meta name="description" content={post.data.description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={post.data.title} />
    <meta property="og:description" content={post.data.description} />
    <meta property="article:published_time" content={post.data.publishedAt.toISOString()} />
    {post.data.updatedAt && <meta property="article:modified_time" content={post.data.updatedAt.toISOString()} />}
    {post.data.coverImage && <meta property="og:image" content={new URL(post.data.coverImage, siteConfig.url).toString()} />}
  </head>
  <body>
    <Header />
    <main class="shell post-shell">
      <a class="back-link" href={basePath}>← Back to index</a>
      <article>
        <header class="post-header">
          <time datetime={post.data.publishedAt.toISOString()}>
            {post.data.publishedAt.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}
          </time>
          <h1>{post.data.title}</h1>
          <p>{post.data.description}</p>
        </header>
        <div class="prose">
          <Content />
        </div>
        <aside class="article-cta">
          <div class="article-cta__copy">
            <p class="article-cta__eyebrow">Built by DRAX</p>
            <h2>Put a marketing department on autopilot.</h2>
          </div>
          <a class="button" href="/pricing">Get DRAX</a>
        </aside>
      </article>
    </main>
    <Footer />
  </body>
</html>
