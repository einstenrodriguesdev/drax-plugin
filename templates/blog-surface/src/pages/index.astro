---
import { getPublishedPosts, postPath } from "../lib/posts";
import { siteConfig } from "../site.config";
import "../styles/global.css";

const posts = await getPublishedPosts();
const basePath = siteConfig.basePath === "/" ? "/" : `${siteConfig.basePath.replace(/\/$/, "")}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{siteConfig.name}</title>
    <meta name="description" content={siteConfig.description} />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href={`${basePath}rss.xml`} />
  </head>
  <body>
    <main class="shell">
      <header class="hero">
        <p class="eyebrow">Editorial</p>
        <h1>{siteConfig.name}</h1>
        <p>{siteConfig.description}</p>
      </header>
      <section class="post-list" aria-label="Published posts">
        {posts.length === 0 && <p class="empty">No published posts yet.</p>}
        {posts.map((post) => (
          <article class="post-card">
            <div>
              <time datetime={post.data.publishedAt.toISOString()}>
                {post.data.publishedAt.toLocaleDateString("en-US", { month: "short", day: "2-digit", year: "numeric" })}
              </time>
              <h2><a href={postPath(post)}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
            </div>
            <ul>
              {post.data.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>
