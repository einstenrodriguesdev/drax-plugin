{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drax.co/schemas/publish-record.schema.json",
  "title": "Drax Publish Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "attemptId",
    "runId",
    "assetId",
    "postClass",
    "adapter",
    "mode",
    "targetAccount",
    "approval",
    "requestedAt",
    "result",
    "evidencePath",
    "contentPackagePath",
    "artifactHashes",
    "publishTarget",
    "dryRun"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "attemptId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "assetId": { "type": "string", "minLength": 1 },
    "postClass": { "type": "string", "minLength": 1 },
    "adapter": { "type": "string", "minLength": 1 },
    "adapterVersion": { "type": "string" },
    "mode": { "enum": ["dry-run", "local-blog-deploy", "official-api", "playwright-experimental", "export-manual"] },
    "targetAccount": { "type": "string", "minLength": 1 },
    "requestedPrivacy": { "type": "string" },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approvedBy", "approvedAt"],
      "properties": {
        "approvedBy": { "type": "string", "minLength": 1 },
        "approvedAt": { "type": "string", "format": "date-time" }
      }
    },
    "requestedAt": { "type": "string", "format": "date-time" },
    "result": { "enum": ["pending", "succeeded", "failed", "rolled-back"] },
    "remoteId": { "type": "string" },
    "evidencePath": { "type": "string", "minLength": 1 },
    "contentPackagePath": { "type": "string", "minLength": 1 },
    "artifactHashes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/hashedFile" }
    },
    "publishTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "slug"],
      "properties": {
        "kind": { "const": "blog-surface" },
        "path": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "minLength": 1 }
      }
    },
    "dryRun": { "type": "boolean" },
    "rollbackResult": { "type": "string" }
  },
  "$defs": {
    "hashedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "mediaType": { "type": "string" }
      }
    }
  }
}
