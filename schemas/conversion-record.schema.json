{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drax.co/schemas/conversion-record.schema.json",
  "title": "Drax Conversion Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "conversionId",
    "event",
    "tokenId",
    "tier",
    "billingInterval",
    "issuedAt",
    "recordedAt",
    "paymentProvider"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "conversionId": { "type": "string", "minLength": 1 },
    "event": { "const": "access-token-issued" },
    "tokenId": { "type": "string", "minLength": 1 },
    "tier": { "enum": ["Startup", "Centaur", "Unicorn"] },
    "billingInterval": { "enum": ["monthly", "annual"] },
    "issuedAt": { "type": "string", "format": "date-time" },
    "recordedAt": { "type": "string", "format": "date-time" },
    "paymentProvider": { "enum": ["stripe", "pagarme"] },
    "paymentReference": { "type": "string", "minLength": 1 },
    "customerReference": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 }
  }
}
