# Optional compatibility pointer to an existing ignored environment file.
DRAX_ENV_PATH=/home/user/conclave-cc/.env

# Runtime selection for the shell launcher.
DRAX_CODEX_BIN=codex
DRAX_CLAUDE_BIN=claude

# Publishing is disabled by default. Enable only after platform approval.
DRAX_PUBLISH_MODE=dry-run
DRAX_VIDEO_ENGINE=python-ffmpeg

# Official API credentials belong in a secret manager or ignored env file.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
